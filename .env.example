PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:kodato@caio#d4r226@localhost:5432/barbertime

# JWT (use um segredo longo e aleatório em produção)
JWT_SECRET=troque_este_segredo_em_producao_use_openssl_rand_base64_32
JWT_EXPIRES_IN=7d

# Grade de horários (fuso America/Sao_Paulo)
SCHEDULE_TIMEZONE=America/Sao_Paulo
SLOT_DURATION_MINUTES=30
DAY_START_HOUR=9
DAY_START_MINUTE=0
DAY_END_HOUR=20
DAY_END_MINUTE=0
# Domingo fechado (Luxon weekday 7)
CLOSED_ON_SUNDAY=true
# Almoço: sem atendimento no intervalo [início, fim)
LUNCH_BREAK_ENABLED=true
LUNCH_START_HOUR=12
LUNCH_START_MINUTE=0
LUNCH_END_HOUR=13
LUNCH_END_MINUTE=0

# RabbitMQ (Sprint 2 — MOM)
RABBITMQ_URL=amqp://barbertime:barbertime@localhost:5673
RABBITMQ_ENABLED=true
